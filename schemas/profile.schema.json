{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.dev/schemas/profile.schema.json",
  "title": "clawtool profile",
  "type": "object",
  "required": ["version", "name", "target"],
  "properties": {
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["local", "ssh"]
        },
        "address": {
          "type": "string"
        },
        "user": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "key_path": {
          "type": "string"
        },
        "host_key_strategy": {
          "type": "string",
          "enum": ["known_hosts", "insecure"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
